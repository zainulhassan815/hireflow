# ---- App ----
DEBUG=true
# Comma-separated list. In prod, set to your real frontend origin(s).
ALLOWED_ORIGINS=http://localhost:5173

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hr_screening

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- ChromaDB ----
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ---- JWT (REQUIRED) ----
# Must be at least 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Field-level encryption (REQUIRED) ----
# Newest key first; older keys still decrypt, enabling rotation. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEYS=

# ---- File Upload ----
MAX_FILE_SIZE_MB=10

# ---- Object Storage (MinIO / S3-compatible) ----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=minio12345
STORAGE_BUCKET=hireflow-documents
STORAGE_REGION=us-east-1

# ---- Vision OCR ----
# Provider for scanned PDFs and images: claude | ollama | tesseract | none
VISION_PROVIDER=tesseract
# Model override (optional):
#   claude  → defaults to claude-sonnet-4-5-20250514
#   ollama  → defaults to llava:13b
VISION_MODEL=
OLLAMA_BASE_URL=http://localhost:11434

# ---- Gmail OAuth (needed from F50; leave blank until then) ----
# Create OAuth client in Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8080/api/auth/gmail/callback

# ---- Gmail resume sync (F51) ----
# How often the beat scheduler fires the fan-out task.
GMAIL_SYNC_INTERVAL_MINUTES=5
# Per-run cap per user. Higher = faster backlog drain, more memory/time per tick.
GMAIL_SYNC_MAX_MESSAGES_PER_RUN=100
# On first sync for a new connection, only look at messages from the last N days.
GMAIL_SYNC_INITIAL_WINDOW_DAYS=7
# Messages stuck in 'claimed' longer than this are reset and retried.
GMAIL_SYNC_CLAIM_TIMEOUT_MINUTES=15

# ---- LLM / Embeddings ----
# LLM_PROVIDER: anthropic | openai | local
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# EMBEDDING_PROVIDER: local (more adapters will land — openai, voyage, …)
# EMBEDDING_MODEL: any HuggingFace model compatible with sentence-transformers.
# Switching the model requires: ./scripts/reindex_embeddings.py
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
