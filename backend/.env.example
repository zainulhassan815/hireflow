# ---- App ----
DEBUG=true
# Comma-separated list. In prod, set to your real frontend origin(s).
ALLOWED_ORIGINS=http://localhost:5173

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hr_screening

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- ChromaDB ----
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ---- JWT (REQUIRED) ----
# Must be at least 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- File Upload ----
MAX_FILE_SIZE_MB=10

# ---- Gmail OAuth (needed from F50; leave blank until then) ----
# Create OAuth client in Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# ---- LLM / Embeddings (needed from F30/F33; leave blank until then) ----
# LLM_PROVIDER: anthropic | openai | local
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
